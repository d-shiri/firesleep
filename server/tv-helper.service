[Unit]
Description=LG webOS power-off helper (tv-helper)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/tv-helper
EnvironmentFile=/etc/tv-helper/env
ExecStart=/home/pi/tv-helper/.venv/bin/uvicorn tv_helper:app --host 0.0.0.0 --port 8765
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
