<?xml version="1.0" encoding="utf-8"?>
<!--
  Android's <domain> directive only accepts hostnames or IP literals — not
  CIDR ranges — so we can't allow only RFC1918 here. The app talks to
  exactly one user-entered LAN IP on port 8765 and never makes any other
  HTTP request, so we open cleartext globally and let runtime behavior be
  the trust boundary.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
